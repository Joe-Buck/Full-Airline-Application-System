# ============================================================================
# DO NOT put real secrets in this file.
# Real values (MONGO_URI, JWT_SECRET) are stored in Replit Secrets and are
# automatically available to the app at runtime via process.env.
#
# This file only exists so the app can fall back to safe defaults during
# local development.  It is committed to GitHub on purpose, with placeholders.
# ============================================================================

MONGO_URI=
PORT=5000
JWT_SECRET=
